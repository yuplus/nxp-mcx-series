Import('rtconfig')
from building import *

cwd = GetCurrentDir()
path = [cwd + '/', cwd + '/drivers', cwd + '/periph0']
src = Split('''
            system_MCXE247.c
            ''')

if rtconfig.PLATFORM in ['gcc']:
    src += ['gcc/startup_MCXE247.S']
elif rtconfig.PLATFORM in ['armcc', 'armclang']:
    src += ['arm/startup_MCXE247.S']
elif rtconfig.PLATFORM in ['iccarm']:
    src += ['iar/startup_MCXE247.s']

src += ['drivers/ela_csec_driver.c']
src += ['drivers/ela_csec_hw_access.c']
src += ['drivers/fsl_acmp.c']
src += ['drivers/fsl_adc12.c']
